# ---- Database (Neon — free tier, no Supabase) ----
# Create a project at https://neon.tech and copy the pooled connection string.
# Looks like: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ---- Session signing ----
# Any long random string. Generate one with:  openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# ---- Google sign-in ----
# From Google Cloud Console > APIs & Services > Credentials > OAuth client (Web).
GOOGLE_CLIENT_ID="xxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="xxxx"
# Comma-separated list of the ONLY emails allowed to sign in.
ALLOWED_EMAILS="you@gmail.com,wife@gmail.com"
# Public base URL of the app. Optional locally (defaults to the request origin),
# but set it in production so OAuth redirects are exact, e.g. https://budget.yourdomain.com
APP_URL="http://localhost:3000"

# ---- AWS S3 (receipt uploads via presigned URLs) ----
AWS_REGION="us-east-1"
S3_BUCKET="your-bucket-name"
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."

# ---- Display ----
# ISO 4217 currency code used to format money (USD, EUR, GBP, TRY, ...)
NEXT_PUBLIC_CURRENCY="USD"
